{
  "seed": 1337,
  "device": "auto",
  "dtype": "auto",

  "data_path": "data/train.txt",

  "streaming": true,
  "chunk_bytes": 4194304,
  "stride": 16,
  "loop": true,

  "context_length": 128,
  "batch_size": 8,
  "num_workers": 2,

  "model": {
    "vocab_size": 256,
    "n_layers": 4,
    "n_heads": 4,
    "d_model": 256,
    "d_ff": 1024,
    "dropout": 0.1
  },

  "train": {
    "max_steps": 5000,
    "lr": 0.0003,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "log_every": 50,
    "save_every": 500,
    "checkpoint_dir": "checkpoints"
  }
}
