{
  "seed": 1337,
  "device": "auto",
  "dtype": "auto",
  "data_path": "data/train.txt",

  "context_length": 256,
  "batch_size": 32,
  "num_workers": 0,

  "model": {
    "vocab_size": 256,
    "n_layers": 4,
    "n_heads": 4,
    "d_model": 256,
    "d_ff": 1024,
    "dropout": 0.1
  },

  "train": {
    "max_steps": 2000,
    "lr": 0.0003,
    "weight_decay": 0.1,
    "grad_clip": 1.0,
    "log_every": 50,
    "save_every": 500,
    "checkpoint_dir": "checkpoints"
  }
}
